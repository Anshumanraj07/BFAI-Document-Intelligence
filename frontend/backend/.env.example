# Backend Environment Variables Example
# Copy this file to .env and fill in your values

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# CORS Configuration - Allowed origins for frontend requests
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:9091,http://127.0.0.1:3000

# API Key for authentication
API_KEY=your-secret-api-key-here

# Database (if using)
DATABASE_URL=postgresql://user:password@localhost:5432/bfai

# Storage path for uploaded documents
STORAGE_PATH=./storage

# Optional: OpenAI API for RAG
OPENAI_API_KEY=your-openai-key-here
