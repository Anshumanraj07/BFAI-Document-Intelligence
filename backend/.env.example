# ====================================
# BFAI Document Intelligence - Backend
# ====================================
# Copy this file to `.env` and fill in your real keys.
# DO NOT commit `.env` to version control.

# --- Application ---
APP_NAME="BFAI Document Intelligence"
APP_ENV=development
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
LOG_LEVEL=INFO

# --- Security ---
# Comma-separated list of allowed CORS origins
CORS_ORIGINS="http://localhost:3000,https://your-frontend.vercel.app"
# Static API key (in production, use a proper auth provider)
API_KEY=change-me-to-a-long-random-string
# Max upload size in bytes (default 10MB)
MAX_FILE_SIZE_BYTES=10485760
# Max bulk upload size in bytes (default 50MB)
MAX_BULK_SIZE_BYTES=52428800
# Max pages per document (Render free tier safety)
MAX_PAGES_PER_DOC=5

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./bfai.db

# --- Vector Database (Qdrant Cloud Free Tier) ---
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_NAME=bfai_documents
QDRANT_VECTOR_SIZE=768

# --- LLM Providers ---
# Get free keys at:
#  - https://console.groq.com (Groq)
#  - https://aistudio.google.com (Gemini)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=models/embedding-001

# --- Storage (Optional: Cloudinary for page images) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Fallback: local storage path
LOCAL_STORAGE_PATH=./storage

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
